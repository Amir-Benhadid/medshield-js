{
  "name": "@nagafenix/medshield-js",
  "version": "1.0.0",
  "description": "Privacy-first PII/PHI sanitization for Medical AI Agents.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "medshield-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/mcp/server.ts --format cjs,esm --clean && tsc --emitDeclarationOnly --declaration --outDir dist",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "test": "tsx --test test/*.test.ts"
  },
  "keywords": [
    "privacy",
    "healthcare",
    "pii",
    "phi",
    "sanitization",
    "hipaa",
    "nlp",
    "ai",
    "mcp",
    "agentic"
  ],
  "author": "Amir-Benhadid",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "compromise": "^14.15.0"
  }
}
